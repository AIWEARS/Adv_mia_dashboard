{
  "name": "mia-diagnosi-pubblicita",
  "version": "1.0.0",
  "description": "MIA - Diagnosi Pubblicita per itsmia.it",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "cd server && npm start",
    "install:all": "npm --prefix client install"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@vercel/functions": "^3.4.3",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
